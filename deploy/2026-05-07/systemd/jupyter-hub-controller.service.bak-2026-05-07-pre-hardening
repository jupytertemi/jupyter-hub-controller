[Unit]
Description=Jupyter Hub.
After=jupyter-hub-migrate.service
Requires=jupyter-hub-migrate.service
Wants=jupyter-hub-celery-camera.service
Wants=jupyter-hub-celery-automation.service
Wants=jupyter-hub-celery-restart-ring.service
Wants=jupyter-hub-celery-beat.service

[Service]
Type=simple
WorkingDirectory=/root/jupyter-container
EnvironmentFile=/root/jupyter-container/.env
Environment=GOOGLE_CLIENT_ID=<REDACTED>
Environment=GOOGLE_CLIENT_SECRET=<REDACTED>
ExecStart=/root/jupyter-container/start_hub_controller.sh
Restart=no

[Install]
WantedBy=multi-user.target
