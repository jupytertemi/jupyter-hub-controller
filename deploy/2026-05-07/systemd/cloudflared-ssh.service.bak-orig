[Unit]
Description=Cloudflare SSH Tunnel (jupyterdevices.com)
After=network-online.target
Wants=network-online.target

[Service]
TimeoutStartSec=15
Type=notify
ExecStart=/usr/bin/cloudflared --no-autoupdate --protocol http2 tunnel run --token <REDACTED>
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
